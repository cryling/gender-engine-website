---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Dark Mode Test">
  <div class="p-10">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Dark Mode Test</h1>
    <p class="text-slate-700 dark:text-slate-300 mb-4">This text should change color when toggling dark mode.</p>
    <div class="bg-slate-200 dark:bg-slate-700 p-4 rounded mb-4">
      <p class="text-slate-900 dark:text-white">This box should change from light gray to dark gray.</p>
    </div>
    <button
      id="test-toggle"
      class="bg-sky-500 text-white px-4 py-2 rounded hover:bg-sky-600"
    >
      Toggle Dark Mode (vanilla JS)
    </button>
    <p id="status" class="mt-4 text-sm font-mono text-slate-600 dark:text-slate-400"></p>
  </div>
  <script is:inline>
    const btn = document.getElementById('test-toggle');
    const status = document.getElementById('status');
    function updateStatus() {
      const hasDark = document.documentElement.classList.contains('dark');
      status.textContent = 'html.dark = ' + hasDark + ' | classList = ' + document.documentElement.className;
    }
    updateStatus();
    btn.addEventListener('click', function() {
      document.documentElement.classList.toggle('dark');
      updateStatus();
    });
  </script>
</Layout>
