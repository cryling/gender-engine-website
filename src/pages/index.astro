---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header";
import { Image } from "astro:assets";

import cyanBlur from "../assets/blur-cyan.png";
import indigoBlur from "../assets/blur-indigo.png";

import TabbedWindow from "../components/TabbedWindow";

import HeroText from "../components/HeroText.astro";

import { GITHUB_REPO } from "../constants.ts";
---

<Layout title="Gender Engine - Find the Gender of any Name">
  <div class="flex w-full flex-col min-h-screen">
    <Header repoHref={GITHUB_REPO} client:load />

    <main class="flex-1">
      <div class="overflow-hidden">
        <div class="py-16 sm:px-2 lg:relative lg:px-0 lg:py-20">
          <div
            class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-x-8 gap-y-16 px-4 lg:grid-cols-[2fr_3fr] lg:px-8 xl:gap-x-16 xl:px-12"
          >
            <HeroText repoHref={GITHUB_REPO} />

            <div class="grow relative lg:static xl:pl-4">
              <div class="relative">
                <Image
                  src={cyanBlur}
                  alt=""
                  height={530}
                  width={530}
                  style="color:transparent"
                  class="absolute -right-64 -top-64"
                />
                <Image
                  src={indigoBlur}
                  alt=""
                  height={567}
                  width={567}
                  style="color:transparent"
                  class="absolute -bottom-40 -right-44"
                />

                <div
                  class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-emerald-300 via-emerald-300/70 to-green-300 opacity-10 blur-lg"
                >
                </div>
                <div
                  class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-emerald-300 via-emerald-300/70 to-green-300 opacity-10"
                >
                </div>
                <div class="animated-border relative rounded-2xl p-px">
                  <div class="relative rounded-2xl bg-neutral-50 dark:bg-[#111111] backdrop-blur overflow-hidden">
                    <TabbedWindow client:load />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="border-t border-neutral-200 dark:border-neutral-700/40">
      <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
          <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 text-sm text-neutral-500 dark:text-neutral-400">
            <span style="font-family: 'JetBrains Mono', monospace;" class="font-medium text-neutral-700 dark:text-neutral-300">Gender Engine</span>
            <span class="hidden sm:block text-neutral-300 dark:text-neutral-600">&middot;</span>
            <span>Open-source &amp; self-hosted</span>
          </div>
          <div class="flex items-center gap-6 text-sm text-neutral-500 dark:text-neutral-400">
            <a href="/docs" class="hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors">Docs</a>
            <a href={GITHUB_REPO} class="hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors">GitHub</a>
          </div>
        </div>
        <div class="mt-8 border-t border-neutral-200 dark:border-neutral-700/40 pt-6">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-neutral-500 dark:text-neutral-400">
            <p>This project does not collect, store, or process any personal data. All API requests are stateless and not logged.</p>
            <p class="shrink-0">Data: <a href="https://dataverse.harvard.edu/dataset.xhtml?persistentId=doi:10.7910/DVN/MSEGSJ" class="hover:text-neutral-700 dark:hover:text-neutral-300 underline underline-offset-2 transition-colors" target="_blank" rel="noopener noreferrer">WGND 2.0</a></p>
          </div>
        </div>
      </div>
    </footer>
  </div>
</Layout>
