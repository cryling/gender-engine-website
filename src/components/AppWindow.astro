---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["pl-4", "pt-4", className]}>
  <svg
    aria-hidden="true"
    viewBox="0 0 42 10"
    fill="none"
    class="h-2.5 w-auto stroke-neutral-500/30"
  >
    <circle cx="5" cy="5" r="4.5"></circle>
    <circle cx="21" cy="5" r="4.5"></circle>
    <circle cx="37" cy="5" r="4.5"></circle>
  </svg>
  <slot />
</div>
