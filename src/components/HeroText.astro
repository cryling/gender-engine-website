---
import { Image } from "astro:assets";
import cyanBlur from "../assets/blur-cyan.png";

interface Props {
  repoHref: string;
}

const { repoHref } = Astro.props;
---

<div class="relative z-10 md:text-center lg:text-left">
  <Image
    src={cyanBlur}
    alt=""
    height={530}
    width={530}
    style="color:transparent"
    class="absolute bottom-full right-full -mb-56 -mr-72 opacity-50"
  />

  <div class="relative">
    <h1
      class="inline bg-gradient-to-r from-indigo-400 via-sky-400 to-indigo-400 dark:from-indigo-200 dark:via-sky-400 dark:to-indigo-200 bg-clip-text text-5xl font-bold tracking-tight text-transparent"
    >
      Find the Gender of any Name
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-600 dark:text-slate-400">
      A simple, no-fuss, free API to determine the gender of any name. Self-hosted and open-source.
    </p>
    <div class="mt-8 flex gap-4 md:justify-center lg:justify-start">
      <a
        class="rounded-full bg-sky-400 py-2.5 px-5 text-sm font-semibold text-white shadow-sm hover:bg-sky-500 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-400 active:bg-sky-600 transition-colors"
        href="/docs"
      >
        Get started
      </a>
      <a
        class="rounded-full py-2.5 px-5 text-sm font-medium text-slate-700 dark:text-slate-300 ring-1 ring-slate-200 dark:ring-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/50 transition-colors"
        href={repoHref}
      >
        View on GitHub
      </a>
    </div>
  </div>
</div>
